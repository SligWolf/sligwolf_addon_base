@BaseClass = SLIGWOLF_BASE_vehicle_disabled_kv
[
	vehiclescript(string) : "[Unused] Vehicle Script File" : "" : "This is unused."
	model(studio) : "Studio model" : "" : "This is the studio model used as in-editor preview. It has no in-game effect."
]

@BaseClass base(SLIGWOLF_BASE_vehicle) = SLIGWOLF_BASE_train
[
	sligwolf_rail_gauge(choices) : "[SW-ADDONS] Rail Gauge (Trains Only)" : "0" : "\nSligWolf's Addon: Train track gauge." =
	[
		"0" : "TODO"
	]
]


@PointClass base(SLIGWOLF_BASE_vehicle, SLIGWOLF_BASE_vehicle_disabled_kv, prop_vehicle_airboat, SLIGWOLF_BASE_vehicle_disabled_kv) size(32 32 32) color(85 190 255) studioprop() = prop_vehicle_sligwolf_airboat :
	"SligWolf Vehicle. It spawns a prop_vehicle_airboat based vehicle by the given spawnname and passes every parameter to the spawned entity."
[
	sligwolf_spawnname(choices) : "[SW-ADDONS] Vehicle spawnname" : "" : "\nSligWolf's Addon: Vehicle spawnname. Used for model, logic and other spawn parameters." =
	[
		"" : "Nothing (No SW-ADDON Vehicle)"
		"sligwolf_hl2coopvehicles_airboat" : "sligwolf_hl2coopvehicles_airboat (Coop Airboat | HL2 Coop Vehicles)"
		"sligwolf_hovercraft" : "sligwolf_hovercraft (Hovercraft)"
		"sligwolf_powerboat_powerboat" : "sligwolf_powerboat_powerboat (Powerboat | Speedboat)"
		"sligwolf_powerboat_speedboat" : "sligwolf_powerboat_speedboat (Speedboat)"
	]

	model(studio) : "Studio model" : "models/airboat.mdl" : "This is the studio model used as in-editor preview. It has no in-game effect."
]

@PointClass base(SLIGWOLF_BASE_vehicle, SLIGWOLF_BASE_vehicle_disabled_kv, prop_vehicle_jeep, SLIGWOLF_BASE_vehicle_disabled_kv) size(32 32 32) color(85 190 255) studioprop() = prop_vehicle_sligwolf_jeep :
	"SligWolf Vehicle. It spawns a prop_vehicle_jeep based vehicle by the given spawnname and passes every parameter to the spawned entity."
[
