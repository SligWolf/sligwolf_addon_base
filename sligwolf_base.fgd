@PointClass base(SLIGWOLF_BASE_train, SLIGWOLF_BASE_vehicle_disabled_kv, prop_vehicle_prisoner_pod, SLIGWOLF_BASE_vehicle_disabled_kv) size(32 32 32) color(85 190 255) studioprop() = prop_vehicle_sligwolf_train :
	"SligWolf Train. It spawns a prop_vehicle_prisoner_pod based train by the given spawnname and passes every parameter to the spawned entity."
[
	sligwolf_spawnname(choices) : "[SW-ADDONS] Vehicle spawnname" : "" : "\nSligWolf's Addon: Vehicle spawnname. Used for model, logic and other spawn parameters." =
	[
		"" : "Nothing (No SW-ADDON Vehicle)"
	]

	model(studio) : "Studio model" : "models/vehicles/prisoner_pod.mdl" : "This is the studio model used as in-editor preview. It has no in-game effect."
]


